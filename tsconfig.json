{
  "compilerOptions": {
    "target": "ESNext",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "allowImportingTsExtensions": true,
    "noEmit": true,
    "strict": true,
    "skipLibCheck": true,
    "paths": {
      "@core/*": ["./core/*"]
    }
  },
  "include": ["core/**/*", "cli/**/*", "mcp/**/*"]
}
